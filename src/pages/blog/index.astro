---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATEGORIES, CATEGORY_MAP } from '../../consts';

const all = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const countByCat = (id: string) => all.filter((p) => p.data.category === id).length;
const recent = all.slice(0, 6);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Blog"
  description="A learning log on RHCSA, Kubernetes, Azure, Infrastructure as Code, configuration management and observability."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow"><span class="en">Learning log</span><span class="fr">Carnet d'apprentissage</span></p>
      <h1 class="section-title reveal">
        <span class="en">Notes from the field</span>
        <span class="fr">Notes de terrain</span>
      </h1>
      <p class="section-sub reveal">
        <span class="en">When I learn something worth keeping — RHCSA, Kubernetes, Azure, IaC, configuration management or observability — it lands here.</span>
        <span class="fr">Quand j'apprends quelque chose qui mérite d'être gardé — RHCSA, Kubernetes, Azure, IaC, gestion de configuration ou observabilité — ça atterrit ici.</span>
      </p>

      <div class="cat-grid">
        {CATEGORIES.map((c) => (
          <a class="cat-card reveal" href={`/blog/${c.id}`}>
            <span class="cat-icon" aria-hidden="true">{c.icon}</span>
            <div class="cat-body">
              <h2>{c.name}</h2>
              <p>{c.description}</p>
            </div>
            <span class="cat-count mono">{countByCat(c.id)} <span class="en">posts</span><span class="fr">articles</span></span>
          </a>
        ))}
      </div>

      {recent.length > 0 && (
        <div class="recent">
          <p class="eyebrow"><span class="en">Recent</span><span class="fr">Récents</span></p>
          <ul class="post-list">
            {recent.map((p) => {
              const c = CATEGORY_MAP[p.data.category];
              const slug = p.id.split('/').pop();
              return (
                <li class="reveal">
                  <a href={`/blog/${p.data.category}/${slug}`}>
                    <time class="mono" datetime={p.data.date.toISOString()}>{fmt(p.data.date)}</time>
                    <span class="pl-cat mono">{c.tag}</span>
                    <span class="pl-title">{p.data.title}</span>
                    <span class="pl-arrow">→</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .cat-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.2rem;
  }
  .cat-card {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: 1.1rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    transition: transform 0.25s var(--ease), border-color 0.25s var(--ease), background 0.25s;
  }
  .cat-card:hover { transform: translateY(-4px); border-color: var(--accent); background: var(--surface-hi); }
  .cat-icon {
    grid-row: 1 / 3;
    font-size: 1.6rem;
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg);
  }
  .cat-body h2 { font-size: 1.25rem; }
  .cat-body p { color: var(--text-mid); font-size: 0.9rem; margin-top: 0.35rem; }
  .cat-count {
    grid-column: 2;
    margin-top: 0.9rem;
    font-size: 0.74rem;
    color: var(--accent);
  }

  .recent { margin-top: 4rem; }
  .recent .eyebrow { margin-bottom: 1.2rem; }
  .post-list { list-style: none; display: grid; gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .post-list a {
    display: grid;
    grid-template-columns: 7rem 8rem 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1.05rem 1.3rem;
    background: var(--surface);
    transition: background 0.2s;
  }
  .post-list a:hover { background: var(--surface-hi); }
  .post-list time { color: var(--text-dim); font-size: 0.76rem; }
  .pl-cat { color: var(--accent); font-size: 0.74rem; }
  .pl-title { font-weight: 500; }
  .pl-arrow { color: var(--text-dim); }
  .post-list a:hover .pl-arrow { color: var(--accent); }

  @media (max-width: 680px) {
    .post-list a { grid-template-columns: 1fr auto; row-gap: 0.3rem; }
    .post-list time, .pl-cat { font-size: 0.72rem; }
    .pl-title { grid-column: 1 / 3; }
  }
</style>
