---
import { SITE } from '../consts';
const year = new Date().getFullYear();
---

<footer>
  <div class="container footer-inner">
    <div class="footer-copy">
      © {year} {SITE.name} —
      <span class="en">DevOps &amp; Systems Engineer</span>
      <span class="fr">Ingénieur DevOps &amp; Systèmes</span>
    </div>
    <div class="footer-links">
      <a class="icon-btn" href={SITE.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn" title="LinkedIn">in</a>
      <a class="icon-btn" href={SITE.github} target="_blank" rel="noopener" aria-label="GitHub" title="GitHub">gh</a>
      <a class="icon-btn" href={`mailto:${SITE.email}`} aria-label="Email" title="Email">@</a>
    </div>
  </div>
</footer>
