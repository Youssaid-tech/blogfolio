---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATEGORIES, CATEGORY_MAP } from '../../consts';

export const getStaticPaths = (async () => {
  return CATEGORIES.map((c) => ({ params: { category: c.id } }));
}) satisfies GetStaticPaths;

const { category } = Astro.params;
const cat = CATEGORY_MAP[category as keyof typeof CATEGORY_MAP];

const posts = (
  await getCollection('blog', ({ data }) => !data.draft && data.category === category)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title={cat.name} description={cat.description}>
  <section class="section">
    <div class="container">
      <a class="back mono reveal" href="/blog">← <span class="en">All categories</span><span class="fr">Toutes les catégories</span></a>

      <p class="eyebrow"><span class="idx">{cat.icon}</span> {cat.tag}</p>
      <h1 class="section-title reveal">{cat.name}</h1>
      <p class="section-sub reveal">{cat.description}</p>

      {posts.length === 0 ? (
        <p class="empty mono reveal">
          <span class="en">// no posts here yet — check back soon</span>
          <span class="fr">// pas encore d'articles ici — revenez bientôt</span>
        </p>
      ) : (
        <ul class="post-list">
          {posts.map((p) => {
            const slug = p.id.split('/').pop();
            return (
              <li class="reveal">
                <a href={`/blog/${cat.id}/${slug}`}>
                  <time class="mono" datetime={p.data.date.toISOString()}>{fmt(p.data.date)}</time>
                  <div>
                    <span class="pl-title">{p.data.title}</span>
                    <span class="pl-desc">{p.data.description}</span>
                  </div>
                  <span class="pl-arrow">→</span>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .back { display: inline-block; color: var(--text-dim); font-size: 0.8rem; margin-bottom: 1.5rem; transition: color 0.2s; }
  .back:hover { color: var(--accent); }
  .empty { margin-top: 2.5rem; color: var(--text-dim); }
  .post-list { margin-top: 3rem; list-style: none; display: grid; gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .post-list a {
    display: grid;
    grid-template-columns: 8rem 1fr auto;
    align-items: center;
    gap: 1.2rem;
    padding: 1.3rem;
    background: var(--surface);
    transition: background 0.2s;
  }
  .post-list a:hover { background: var(--surface-hi); }
  .post-list time { color: var(--text-dim); font-size: 0.76rem; }
  .pl-title { display: block; font-weight: 500; font-size: 1.05rem; }
  .pl-desc { display: block; color: var(--text-mid); font-size: 0.88rem; margin-top: 0.2rem; }
  .pl-arrow { color: var(--text-dim); }
  .post-list a:hover .pl-arrow { color: var(--accent); }

  @media (max-width: 680px) {
    .post-list a { grid-template-columns: 1fr auto; }
    .post-list time { grid-column: 1 / 3; }
  }
</style>
