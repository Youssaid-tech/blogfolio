---
import type { GetStaticPaths } from 'astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { CATEGORY_MAP } from '../../../consts';

export const getStaticPaths = (async () => {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { category: post.data.category, slug: post.id.split('/').pop() },
    props: { post },
  }));
}) satisfies GetStaticPaths;

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content, headings } = await render(post);
const cat = CATEGORY_MAP[post.data.category];

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="section post">
    <div class="container post-wrap">
      <header class="post-head">
        <a class="back mono" href={`/blog/${cat.id}`}>← {cat.name}</a>
        <h1>{post.data.title}</h1>
        <p class="post-desc">{post.data.description}</p>
        <div class="post-meta mono">
          <span class="post-badge">{cat.icon} {cat.name}</span>
          <time datetime={post.data.date.toISOString()}>{fmt(post.data.date)}</time>
          {post.data.updated && (
            <span class="upd">· updated {fmt(post.data.updated)}</span>
          )}
        </div>
        {post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map((t) => <span class="tag mono">#{t}</span>)}
          </div>
        )}
      </header>

      <div class="post-layout">
        {toc.length > 2 && (
          <aside class="toc">
            <p class="mono toc-label">On this page</p>
            <nav>
              {toc.map((h) => (
                <a href={`#${h.slug}`} class={h.depth === 3 ? 'toc-sub' : ''}>{h.text}</a>
              ))}
            </nav>
          </aside>
        )}
        <div class="prose">
          <Content />
        </div>
      </div>

      <footer class="post-foot">
        <a class="btn" href={`/blog/${cat.id}`}>← <span class="en">More in {cat.name}</span><span class="fr">Plus dans {cat.name}</span></a>
        <a class="btn" href="/blog"><span class="en">All categories</span><span class="fr">Toutes les catégories</span></a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .post-wrap { max-width: 880px; }
  .back { color: var(--text-dim); font-size: 0.8rem; transition: color 0.2s; }
  .back:hover { color: var(--accent); }
  .post-head { padding-bottom: 2rem; border-bottom: 1px solid var(--border); margin-bottom: 2.5rem; }
  .post-head h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-top: 1.2rem;
    line-height: 1.08;
  }
  .post-desc { color: var(--text-mid); font-size: 1.1rem; margin-top: 1rem; max-width: 60ch; }
  .post-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.8rem; margin-top: 1.5rem; font-size: 0.78rem; color: var(--text-dim); }
  .post-badge { color: var(--accent); }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 1rem; }
  .post-tags .tag {
    font-size: 0.74rem;
    padding: 0.28rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-mid);
  }

  .post-layout { display: grid; grid-template-columns: 1fr; gap: 2.5rem; }
  .toc {
    position: sticky;
    top: 90px;
    align-self: start;
    font-size: 0.85rem;
  }
  .toc-label { color: var(--text-dim); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.8rem; }
  .toc nav { display: grid; gap: 0.5rem; border-left: 1px solid var(--border); }
  .toc nav a { padding-left: 1rem; color: var(--text-mid); transition: color 0.2s; border-left: 2px solid transparent; margin-left: -1px; }
  .toc nav a:hover { color: var(--accent); border-left-color: var(--accent); }
  .toc-sub { padding-left: 1.8rem !important; font-size: 0.8rem; }

  @media (min-width: 1040px) {
    .post-layout { grid-template-columns: 220px 1fr; }
    .toc { order: -1; }
  }

  /* ---------- Prose ---------- */
  .prose :global(h2) { font-size: 1.6rem; margin: 2.5rem 0 1rem; scroll-margin-top: 90px; letter-spacing: -0.02em; }
  .prose :global(h3) { font-size: 1.25rem; margin: 2rem 0 0.8rem; scroll-margin-top: 90px; }
  .prose :global(p) { margin: 1rem 0; color: var(--text-mid); }
  .prose :global(a) { color: var(--text); text-decoration: underline; text-decoration-color: var(--accent); text-underline-offset: 3px; }
  .prose :global(a:hover) { color: var(--accent); }
  .prose :global(ul), .prose :global(ol) { margin: 1rem 0; padding-left: 1.4rem; color: var(--text-mid); }
  .prose :global(li) { margin: 0.4rem 0; }
  .prose :global(li::marker) { color: var(--accent); }
  .prose :global(strong) { color: var(--text); }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 0.4rem 0 0.4rem 1.2rem;
    margin: 1.5rem 0;
    color: var(--text-mid);
    font-style: italic;
  }
  .prose :global(code:not(.astro-code code)) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 0.12em 0.4em;
    border-radius: 5px;
  }
  .prose :global(.astro-code) { margin: 1.5rem 0; }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--border); margin: 2.5rem 0; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.92rem; }
  .prose :global(th), .prose :global(td) { border: 1px solid var(--border); padding: 0.6rem 0.8rem; text-align: left; }
  .prose :global(th) { background: var(--surface-2); font-family: var(--font-mono); font-size: 0.82rem; }
  .prose :global(img) { border-radius: var(--radius-sm); border: 1px solid var(--border); margin: 1.5rem 0; }

  .post-foot { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 3.5rem; padding-top: 2rem; border-top: 1px solid var(--border); }
</style>
