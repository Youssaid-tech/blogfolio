---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORY_MAP, SITE } from '../consts';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

const skills = [
  { name: 'DevOps & CI/CD', items: ['GitLab CI/CD', 'GitHub Actions', 'Jenkins', 'Azure DevOps', 'Pipelines', 'Artifacts'] },
  { name: 'Containers & Orchestration', items: ['Kubernetes', 'Docker', 'Podman', 'Helm', 'Rancher', 'Azure AKS', 'AWS EKS', 'GCP GKE', 'RBAC'] },
  { name: 'Infrastructure as Code', items: ['Terraform', 'Ansible', 'Ansible Core', 'Git', 'YAML', 'JSON'] },
  { name: 'Cloud', items: ['Microsoft Azure', 'Azure Backup', 'Azure Monitor', 'AWS', 'GCP', 'Office 365'] },
  { name: 'Systems & Virtualization', items: ['Linux RHEL', 'Ubuntu', 'Debian', 'IBM AIX', 'VMware ESXi', 'vSphere', 'vCenter', 'Proxmox VE', 'KVM', 'LXC'] },
  { name: 'Monitoring & Logging', items: ['Prometheus', 'Grafana', 'ELK Stack', 'Zabbix', 'Nagios', 'PRTG', 'Dynatrace', 'Azure Monitor'] },
  { name: 'Networking & Security', items: ['Nginx', 'HAProxy', 'Traefik', 'F5', 'Azure LB', 'VPN', 'Keycloak', 'System Hardening'] },
  { name: 'Scripting & Programming', items: ['Python', 'Bash', 'PowerShell', 'boto3'] },
  { name: 'Databases & ITSM', items: ['PostgreSQL HA', 'DB2', 'GLPI', 'OTRS', 'ITIL'] },
];
---

<BaseLayout>
  <!-- ============ HERO ============ -->
  <section id="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-main">
        <div class="hero-status">
          <span class="pulse"></span>
          <span class="en">Available for new opportunities</span>
          <span class="fr">Disponible pour de nouvelles opportunités</span>
        </div>

        <h1 class="hero-name">Youssef<br />OUSSAID<span class="accent">.</span></h1>

        <p class="hero-role mono">
          <span class="en">DevOps &amp; Systems Engineer · Azure Cloud Specialist</span>
          <span class="fr">Ingénieur DevOps &amp; Systèmes · Spécialiste Azure Cloud</span>
        </p>

        <p class="hero-desc en">
          9 years building and automating resilient infrastructure. Azure Cloud, Kubernetes
          orchestration, CI/CD pipelines and Linux systems — with a habit of writing down what I learn.
        </p>
        <p class="hero-desc fr">
          9 ans à concevoir et automatiser des infrastructures résilientes. Azure Cloud, orchestration
          Kubernetes, pipelines CI/CD et systèmes Linux — avec l'habitude de documenter ce que j'apprends.
        </p>

        <div class="hero-actions">
          <a href="#experience" class="btn btn-primary">
            <span class="en">↓ View experience</span><span class="fr">↓ Voir l'expérience</span>
          </a>
          <a href="/blog" class="btn">
            <span class="en">Read the blog →</span><span class="fr">Lire le blog →</span>
          </a>
        </div>
      </div>

      <!-- terminal-style identity card -->
      <aside class="hero-card">
        <div class="hc-bar">
          <span></span><span></span><span></span>
          <em class="mono">~/whoami</em>
        </div>
        <div class="hc-body mono">
          <div class="hc-row"><span>role</span><b>devops · sre · sysadmin</b></div>
          <div class="hc-row"><span>exp</span><b>9 years</b></div>
          <div class="hc-row"><span>cloud</span><b>Azure · AWS · GCP</b></div>
          <div class="hc-row"><span>certs</span><b>AZ-104 · AZ-400</b></div>
          <div class="hc-row"><span>loc</span><b>France</b></div>
          <div class="hc-row"><span>langs</span><b>FR · EN · AR</b></div>
          <div class="hc-row hc-uptime">
            <span>status</span><b class="accent">● operational</b>
          </div>
        </div>
      </aside>
    </div>

    <div class="hero-stats container">
      <div class="stat"><b>9+</b><span class="en">years exp.</span><span class="fr">ans d'exp.</span></div>
      <div class="stat"><b>15+</b><span class="en">projects</span><span class="fr">projets</span></div>
      <div class="stat"><b>2</b><span class="en">Azure certs</span><span class="fr">certif. Azure</span></div>
      <div class="stat"><b>3</b><span class="en">languages</span><span class="fr">langues</span></div>
    </div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section id="about" class="section">
    <div class="container about-grid">
      <div>
        <p class="eyebrow"><span class="idx">01</span> <span class="en">About</span><span class="fr">À propos</span></p>
        <h2 class="section-title reveal">
          <span class="en">Infrastructure that never sleeps</span>
          <span class="fr">Des infrastructures qui ne dorment jamais</span>
        </h2>

        <div class="en about-copy">
          <p class="reveal">DevOps and Systems Engineer with <strong>9 years of experience</strong>, specializing in infrastructure automation, Azure Cloud, and container orchestration with Kubernetes, Docker and Podman.</p>
          <p class="reveal">Expert in CI/CD with GitLab CI/CD, GitHub Actions and Azure DevOps. Proven track record designing high-availability architectures and automating complex deployments across on-premise and cloud.</p>
          <p class="reveal">Deep expertise in Linux administration (RHEL, Ubuntu, Debian) and virtualization (VMware ESXi, Proxmox). Passionate about reliability engineering, monitoring and DevOps culture.</p>
        </div>
        <div class="fr about-copy">
          <p class="reveal">Ingénieur DevOps et Systèmes avec <strong>9 ans d'expérience</strong>, spécialisé dans l'automatisation d'infrastructure, Azure Cloud et l'orchestration de conteneurs avec Kubernetes, Docker et Podman.</p>
          <p class="reveal">Expert CI/CD avec GitLab CI/CD, GitHub Actions et Azure DevOps. Expérience avérée dans la conception d'architectures haute disponibilité et l'automatisation de déploiements complexes.</p>
          <p class="reveal">Solide expertise en administration Linux (RHEL, Ubuntu, Debian) et virtualisation (VMware ESXi, Proxmox). Passionné par la fiabilité, le monitoring et la culture DevOps.</p>
        </div>
      </div>

      <aside class="certs">
        <p class="eyebrow"><span class="en">Certifications</span><span class="fr">Certifications</span></p>
        <div class="cert reveal"><span class="cert-yr mono">2022</span><div><b>AZ-400</b><small class="en">Azure DevOps Expert</small><small class="fr">Expert DevOps Azure</small></div></div>
        <div class="cert reveal"><span class="cert-yr mono">2022</span><div><b>AZ-104</b><small class="en">Azure Administrator Associate</small><small class="fr">Administrateur Azure Associate</small></div></div>
        <div class="cert reveal"><span class="cert-yr mono">2023</span><div><b><span class="en">Master's Degree</span><span class="fr">Master</span></b><small class="en">Computer Eng. — Big Data &amp; Cloud</small><small class="fr">Ingénierie Info. — Big Data &amp; Cloud</small></div></div>
        <div class="cert reveal"><span class="cert-yr mono">2021</span><div><b><span class="en">Pro Bachelor's</span><span class="fr">Licence Pro</span></b><small class="en">Network Systems &amp; Security</small><small class="fr">Réseau Système &amp; Sécurité</small></div></div>
      </aside>
    </div>
  </section>

  <!-- ============ SKILLS ============ -->
  <section id="skills" class="section">
    <div class="container">
      <p class="eyebrow"><span class="idx">02</span> <span class="en">Stack</span><span class="fr">Stack</span></p>
      <h2 class="section-title reveal">
        <span class="en">Tools &amp; technologies</span>
        <span class="fr">Outils &amp; technologies</span>
      </h2>
      <p class="section-sub reveal">
        <span class="en">Hands-on across the full infrastructure and DevOps stack.</span>
        <span class="fr">Expérience opérationnelle sur l'ensemble du stack infrastructure et DevOps.</span>
      </p>

      <div class="skills-grid">
        {skills.map((s) => (
          <div class="skill reveal">
            <h3>{s.name}</h3>
            <div class="tags">
              {s.items.map((t) => <span class="tag mono">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ EXPERIENCE ============ -->
  <section id="experience" class="section">
    <div class="container">
      <p class="eyebrow"><span class="idx">03</span> <span class="en">Experience</span><span class="fr">Expérience</span></p>
      <h2 class="section-title reveal">
        <span class="en">9 years of engineering</span>
        <span class="fr">9 ans d'ingénierie</span>
      </h2>

      <div class="timeline">
        <article class="job reveal">
          <div class="job-head">
            <h3><span class="en">Ministry of National Education — France</span><span class="fr">Ministère de l'Éducation Nationale — France</span></h3>
            <span class="job-when mono">Dec 2024 — <span class="en">Present</span><span class="fr">Présent</span></span>
          </div>
          <p class="job-role"><span class="en">Expert in Production &amp; Operating Systems</span><span class="fr">Expert en systèmes de production et d'exploitation</span></p>
          <ul>
            <li class="en">Management of Rancher / Kubernetes clusters in production</li>
            <li class="fr">Gestion de clusters Rancher / Kubernetes en production</li>
            <li class="en">N3 support for production applications and incident management</li>
            <li class="fr">Support N3 des applications de production et gestion des incidents</li>
            <li class="en">CI/CD pipelines and deployment automation, full project documentation</li>
            <li class="fr">Pipelines CI/CD et automatisation des déploiements, documentation complète</li>
          </ul>
          <div class="tags">
            <span class="tag mono">Kubernetes</span><span class="tag mono">Rancher</span><span class="tag mono">GitLab CI</span><span class="tag mono">PostgreSQL</span><span class="tag mono">Prometheus</span><span class="tag mono">Grafana</span>
          </div>
        </article>

        <article class="job reveal">
          <div class="job-head">
            <h3>SKYLLIT</h3>
            <span class="job-when mono">Mar 2023 — Nov 2024</span>
          </div>
          <p class="job-role">DevOps &amp; Cloud Engineer</p>
          <ul>
            <li class="en">Design and implementation of Azure Cloud architectures for multiple clients</li>
            <li class="fr">Conception et implémentation d'architectures Azure Cloud pour plusieurs clients</li>
            <li class="en">PostgreSQL HA clusters, SOC2 compliance, GCP Kubernetes, Zabbix monitoring</li>
            <li class="fr">Clusters PostgreSQL HA, conformité SOC2, Kubernetes GCP, monitoring Zabbix</li>
            <li class="en">CI/CD with GitHub Actions &amp; Terraform, ITSM (GLPI / OTRS) with Keycloak</li>
            <li class="fr">CI/CD avec GitHub Actions &amp; Terraform, ITSM (GLPI / OTRS) avec Keycloak</li>
          </ul>
          <div class="tags">
            <span class="tag mono">Azure</span><span class="tag mono">Terraform</span><span class="tag mono">GitHub Actions</span><span class="tag mono">PostgreSQL HA</span><span class="tag mono">GCP</span><span class="tag mono">Zabbix</span>
          </div>
        </article>

        <article class="job reveal">
          <div class="job-head">
            <h3>Groupe LabelVie</h3>
            <span class="job-when mono">Aug 2022 — Feb 2023</span>
          </div>
          <p class="job-role"><span class="en">Linux Systems &amp; Virtualization Engineer</span><span class="fr">Ingénieur Systèmes Linux &amp; Virtualisation</span></p>
          <ul>
            <li class="en">Administration of Linux &amp; AIX servers, Ansible centralization and patching</li>
            <li class="fr">Administration des serveurs Linux &amp; AIX, centralisation Ansible et patching</li>
            <li class="en">Monitoring with PRTG, Prometheus, Dynatrace; VMware vSphere 7 upgrade</li>
            <li class="fr">Monitoring avec PRTG, Prometheus, Dynatrace ; upgrade VMware vSphere 7</li>
          </ul>
          <div class="tags">
            <span class="tag mono">Ansible</span><span class="tag mono">VMware</span><span class="tag mono">PRTG</span><span class="tag mono">Dynatrace</span><span class="tag mono">Linux</span><span class="tag mono">AIX</span>
          </div>
        </article>

        <article class="job reveal">
          <div class="job-head">
            <h3>Percall Développement</h3>
            <span class="job-when mono">Apr 2018 — Aug 2022</span>
          </div>
          <p class="job-role"><span class="en">Systems &amp; Network Administrator</span><span class="fr">Administrateur Systèmes &amp; Réseau</span></p>
          <ul>
            <li class="en">DevOps implementation and infrastructure migration to Azure</li>
            <li class="fr">Implémentation DevOps et migration d'infrastructure vers Azure</li>
            <li class="en">Jenkins, Artifactory, Docker, SonarQube, Prometheus/Grafana, Azure Backup, O365</li>
            <li class="fr">Jenkins, Artifactory, Docker, SonarQube, Prometheus/Grafana, Azure Backup, O365</li>
          </ul>
          <div class="tags">
            <span class="tag mono">Azure</span><span class="tag mono">Jenkins</span><span class="tag mono">Docker</span><span class="tag mono">Artifactory</span><span class="tag mono">Office 365</span>
          </div>
        </article>

        <article class="job reveal">
          <div class="job-head">
            <h3>Previance Assurance</h3>
            <span class="job-when mono">Feb 2017 — Apr 2018</span>
          </div>
          <p class="job-role"><span class="en">Systems &amp; Network Technician</span><span class="fr">Technicien Systèmes &amp; Réseau</span></p>
          <ul>
            <li class="en">Asterisk VoIP, Active Directory &amp; GPO, network equipment, N1/N2 helpdesk</li>
            <li class="fr">VoIP Asterisk, Active Directory &amp; GPO, équipements réseau, helpdesk N1/N2</li>
          </ul>
          <div class="tags">
            <span class="tag mono">Linux</span><span class="tag mono">Asterisk</span><span class="tag mono">Windows Server</span><span class="tag mono">AD</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ BLOG TEASER ============ -->
  <section id="writing" class="section">
    <div class="container">
      <div class="blog-head">
        <div>
          <p class="eyebrow"><span class="idx">04</span> <span class="en">Learning log</span><span class="fr">Carnet d'apprentissage</span></p>
          <h2 class="section-title reveal">
            <span class="en">Things I'm learning</span>
            <span class="fr">Ce que j'apprends</span>
          </h2>
        </div>
        <a href="/blog" class="btn"><span class="en">All posts →</span><span class="fr">Tous les articles →</span></a>
      </div>

      {posts.length === 0 ? (
        <p class="section-sub reveal">
          <span class="en">Posts are on the way — RHCSA, Kubernetes, Azure, IaC, configuration management and observability.</span>
          <span class="fr">Les articles arrivent — RHCSA, Kubernetes, Azure, IaC, gestion de configuration et observabilité.</span>
        </p>
      ) : (
        <div class="post-grid">
          {posts.map((p) => {
            const c = CATEGORY_MAP[p.data.category];
            const slug = p.id.split('/').pop();
            return (
              <a class="post-card reveal" href={`/blog/${p.data.category}/${slug}`}>
                <span class="post-cat mono">{c.icon} {c.name}</span>
                <h3>{p.data.title}</h3>
                <p>{p.data.description}</p>
                <time class="mono" datetime={p.data.date.toISOString()}>{fmt(p.data.date)}</time>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- ============ CONTACT ============ -->
  <section id="contact" class="section">
    <div class="container contact-grid">
      <div>
        <p class="eyebrow"><span class="idx">05</span> Contact</p>
        <h2 class="section-title reveal">
          <span class="en">Let's work together</span>
          <span class="fr">Travaillons ensemble</span>
        </h2>
        <p class="section-sub reveal">
          <span class="en">Open to DevOps, Cloud and Systems Engineering opportunities. A project, a role, or a question — reach out.</span>
          <span class="fr">Ouvert aux opportunités DevOps, Cloud et Ingénierie Systèmes. Un projet, un poste ou une question — contactez-moi.</span>
        </p>
      </div>

      <div class="contact-links">
        <a class="clink reveal" href={`mailto:${SITE.email}`}>
          <span class="mono">email</span><b>{SITE.email}</b>
        </a>
        <a class="clink reveal" href={SITE.linkedin} target="_blank" rel="noopener">
          <span class="mono">linkedin</span><b>youssef-oussaid</b>
        </a>
        <a class="clink reveal" href={SITE.github} target="_blank" rel="noopener">
          <span class="mono">github</span><b>Youssaid-tech</b>
        </a>
        <div class="clink reveal">
          <span class="mono">location</span><b>France</b>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---------- Hero ---------- */
  #hero {
    position: relative;
    padding-top: clamp(3rem, 8vw, 6rem);
    padding-bottom: clamp(2rem, 5vw, 4rem);
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    top: -30%;
    right: -10%;
    width: 60vw;
    height: 60vw;
    max-width: 760px;
    max-height: 760px;
    background: radial-gradient(circle, color-mix(in srgb, var(--accent) 22%, transparent), transparent 62%);
    filter: blur(30px);
    pointer-events: none;
    opacity: 0.7;
    z-index: 0;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.5fr 0.9fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    min-height: 64vh;
  }
  .hero-status {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-mid);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 0.4rem 0.9rem;
    background: var(--surface);
  }
  .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 70%, transparent);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 60%, transparent); }
    70% { box-shadow: 0 0 0 9px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }
  .hero-name {
    font-size: clamp(3.2rem, 11vw, 7.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-top: 1.4rem;
  }
  .hero-role {
    margin-top: 0.6rem;
    color: var(--text-mid);
    font-size: clamp(0.85rem, 2vw, 1rem);
    letter-spacing: 0.01em;
  }
  .hero-desc {
    margin-top: 1.4rem;
    max-width: 50ch;
    color: var(--text-mid);
  }
  .hero-actions {
    margin-top: 2rem;
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  /* terminal card */
  .hero-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .hc-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 0.9rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface-2);
  }
  .hc-bar span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border-hi);
  }
  .hc-bar em {
    margin-left: auto;
    font-style: normal;
    font-size: 0.72rem;
    color: var(--text-dim);
  }
  .hc-body {
    padding: 1.1rem 1.2rem;
    font-size: 0.82rem;
  }
  .hc-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.45rem 0;
    border-bottom: 1px dashed var(--border);
  }
  .hc-row:last-child { border-bottom: 0; }
  .hc-row span { color: var(--text-dim); }
  .hc-row b { font-weight: 500; color: var(--text); }
  .hc-uptime b { font-weight: 600; }

  .hero-stats {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: clamp(2rem, 5vw, 3.5rem);
    border-top: 1px solid var(--border);
    padding-top: 2rem;
  }
  .stat b {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 600;
    display: block;
    color: var(--accent);
  }
  .stat span {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ---------- About ---------- */
  .about-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .about-copy p { margin-top: 1rem; color: var(--text-mid); }
  .about-copy strong { color: var(--text); }
  .certs {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem;
    background: var(--surface);
    display: grid;
    gap: 0.4rem;
  }
  .certs .eyebrow { margin-bottom: 0.6rem; }
  .cert {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    padding: 0.7rem 0;
    border-bottom: 1px dashed var(--border);
  }
  .cert:last-child { border-bottom: 0; }
  .cert-yr { color: var(--accent); font-size: 0.8rem; min-width: 3rem; }
  .cert b { display: block; font-family: var(--font-display); font-size: 1.05rem; }
  .cert small { display: block; color: var(--text-dim); font-size: 0.82rem; }

  /* ---------- Skills ---------- */
  .skills-grid {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .skill {
    background: var(--surface);
    padding: 1.4rem;
    transition: background 0.25s var(--ease);
  }
  .skill:hover { background: var(--surface-hi); }
  .skill h3 {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    margin-bottom: 0.9rem;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tag {
    font-size: 0.74rem;
    padding: 0.28rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-mid);
    background: var(--bg);
    transition: border-color 0.2s, color 0.2s;
  }
  .skill:hover .tag { border-color: var(--border-hi); }

  /* ---------- Experience ---------- */
  .timeline {
    margin-top: 2.5rem;
    border-left: 1px solid var(--border);
    padding-left: clamp(1.2rem, 3vw, 2.2rem);
    display: grid;
    gap: 2.2rem;
  }
  .job { position: relative; }
  .job::before {
    content: '';
    position: absolute;
    left: calc(-1 * clamp(1.2rem, 3vw, 2.2rem) - 5px);
